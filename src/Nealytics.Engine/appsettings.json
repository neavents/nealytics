{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "TelemetryEngine": {
    "ClickHouseConnectionString": "Host=127.0.0.1;Port=9000;Database=nealytics_core;",
    "WriteAheadLogDirectory": "/var/log/nealytics_engine/",
    "MemoryChannelCapacity": 100000,
    "DatabaseBatchCommitSize": 10000,
    "ForceFlushIntervalSeconds": 3,
    "AllowedProjectKeys": "",
    "JwtSymmetricKey": "",
    "MaxRequestBodyBytes": 1048576,
    "MaxQueryLimit": 10000,
    "RateLimitPermitCount": 1000,
    "RateLimitWindowSeconds": 10,
    "RateLimitQueueSize": 500,
    "CorsAllowedOrigins": "",
    "JwtClockSkewSeconds": 30,
    "MaxInsertRetries": 5,
    "RetryBackoffCeilingMs": 30000,
    "DefaultSessionQueryRangeHours": 24,
    "ConnectionPoolSize": 16
  }
}
